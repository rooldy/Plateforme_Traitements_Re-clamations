# Configuration Airflow - Projet Réclamations
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.
ENV_FILE_PATH=.env

# Credentials Airflow
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# PostgreSQL
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB_AIRFLOW=airflow
POSTGRES_DB_METIER=reclamations_db

# Timezone
TZ=Europe/Paris
